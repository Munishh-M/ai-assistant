# Copy this file to ".env" and fill in your details.
# Pick ONE provider below and uncomment/edit its lines.

# ---- Groq (free tier, very fast, open-source models like Llama 3.3) ----
API_BASE_URL=https://api.groq.com/openai/v1
API_KEY=your_groq_api_key_here
MODEL=llama-3.3-70b-versatile

# ---- OpenRouter (many open-source models, some free) ----
# API_BASE_URL=https://openrouter.ai/api/v1
# API_KEY=your_openrouter_api_key_here
# MODEL=meta-llama/llama-3.3-70b-instruct:free

# ---- Together AI ----
# API_BASE_URL=https://api.together.xyz/v1
# API_KEY=your_together_api_key_here
# MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# ---- Ollama (run models 100% locally, no API key needed) ----
# API_BASE_URL=http://localhost:11434/v1
# API_KEY=ollama
# MODEL=llama3.3

# ---- Login/signup (required) ----
# MongoDB stores user accounts. Same setup as your other projects:
# https://www.mongodb.com/cloud/atlas/register -> free M0 cluster
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/ai-assistant?retryWrites=true&w=majority

# JWT_SECRET can be any long random string — it signs login tokens.
# Generate one quickly by running: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

PORT=3000
